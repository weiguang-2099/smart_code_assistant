# Smart Code Assistant Backend Configuration
# 复制此文件为 .env 并填写实际值

# ==================== 环境配置 ====================
# development | production
FASTAPI_ENV=development
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3307
DB_USER=appuser
DB_PASSWORD=your_secure_password_here
DB_NAME=smart_code_assistant
# 或直接使用连接字符串
DATABASE_URL=mysql+aiomysql://appuser:your_secure_password_here@localhost:3307/smart_code_assistant

# ==================== 安全配置 ====================
# 必须设置！生产环境使用强密钥 (至少32字符)
SECRET_KEY=your_secret_key_at_least_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS 配置 ====================
# 开发环境 CORS 源 (默认已配置)
# CORS_ORIGINS_DEV=["http://localhost:5173","http://localhost:3000"]

# 生产环境 CORS 源 (必须显式配置！)
# 示例: CORS_ORIGINS_PROD=["https://your-domain.com","https://app.your-domain.com"]
CORS_ORIGINS_PROD=[]

# ==================== AI 服务配置 ====================
# 智谱 AI API Key (必填)
ZHIPUAI_API_KEY=your_zhipuai_api_key

# LLM provider switch: zhipuai (default) or openai.
# Empty values resolve to per-provider presets; LLM_API_KEY falls back to ZHIPUAI_API_KEY.
LLM_PROVIDER=zhipuai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MODEL_FAST=
LLM_MODEL_QUALITY=
LLM_MODEL_LIGHT=

# Datalab Marker API (PDF解析)
DATALAB_API_KEY=your_datalab_api_key
DATALAB_API_URL=https://www.datalab.to/api/v1/marker

# ==================== Neo4j 配置 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ==================== ChromaDB 配置 ====================
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIR=./data/chroma

# ==================== 代码图谱配置 ====================
CODE_GRAPH_MAX_DEPTH=5
CODE_GRAPH_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CODE_GRAPH_MAX_ENTITIES=100
CODE_GRAPH_ENABLE_SEMANTIC_SEARCH=true

# ==================== 限流配置 ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_LOGIN_REQUESTS=20
