# Database Configuration
DATABASE_URL=mysql+aiomysql://appuser:apppassword@localhost:3307/smart_code_assistant
DB_HOST=localhost
DB_PORT=3307
DB_USER=appuser
DB_PASSWORD=apppassword
DB_NAME=smart_code_assistant

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Sentry (optional - leave blank to disable)
# Backend
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=
# Frontend (must be prefixed with VITE_ to be exposed to the browser bundle)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.0
VITE_SENTRY_RELEASE=
